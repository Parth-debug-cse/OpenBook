# API Server
API_HOST=127.0.0.1
API_PORT=8000
OPENBOOK_API_KEY=

# LLM Configuration
LLM_N_CTX=2048
LLM_N_THREADS=4
LLM_N_BATCH=512
LLM_N_GPU_LAYERS=0
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_REPEAT_PENALTY=1.1
LLM_TOP_K=40
LLM_TOP_P=0.95

# Embedding Configuration
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5-Q
EMBED_DIM=768

# Ingestion
CHUNK_SIZE=400
CHUNK_OVERLAP=60
SUPPORTED_EXTS=.pdf,.txt,.md

# Vector Database
LANCEDB_TABLE=openbook_chunks
LANCEDB_RESET_ON_DIM_CHANGE=true

# Retrieval
TOP_K_RETRIEVAL=5

# Text-to-Speech
TTS_VOICE=af_sarah
TTS_SPEED=1.0
TTS_SAMPLE_RATE=24000
TTS_MAX_CHARS=2000
TTS_CACHE_MAX_FILES=200
TTS_CACHE_MAX_BYTES=209715200
TTS_CACHE_TTL_SECONDS=604800

# Upload Limits (bytes)
MAX_UPLOAD_BYTES=52428800
